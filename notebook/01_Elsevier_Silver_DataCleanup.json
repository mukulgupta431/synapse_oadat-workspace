{
	"name": "01_Elsevier_Silver_DataCleanup",
	"properties": {
		"nbformat": 4,
		"nbformat_minor": 2,
		"bigDataPool": {
			"referenceName": "oadatSparkPook",
			"type": "BigDataPoolReference"
		},
		"sessionProperties": {
			"driverMemory": "28g",
			"driverCores": 4,
			"executorMemory": "28g",
			"executorCores": 4,
			"numExecutors": 2,
			"runAsWorkspaceSystemIdentity": false,
			"conf": {
				"spark.dynamicAllocation.enabled": "false",
				"spark.dynamicAllocation.minExecutors": "2",
				"spark.dynamicAllocation.maxExecutors": "2",
				"spark.autotune.trackingId": "7ccfae02-351d-42a8-af97-3e1b7457d2cd"
			}
		},
		"metadata": {
			"saveOutput": true,
			"synapse_widget": {
				"version": "0.1"
			},
			"enableDebugMode": false,
			"language_info": {
				"name": "python"
			},
			"a365ComputeOptions": {
				"id": "/subscriptions/66930ddf-fa17-4910-b3d8-e514f9eb05b0/resourceGroups/oadat/providers/Microsoft.Synapse/workspaces/oadat-workspace/bigDataPools/oadatSparkPook",
				"name": "oadatSparkPook",
				"type": "Spark",
				"endpoint": "https://oadat-workspace.dev.azuresynapse.net/livyApi/versions/2019-11-01-preview/sparkPools/oadatSparkPook",
				"auth": {
					"type": "AAD",
					"authResource": "https://dev.azuresynapse.net",
					"authHeader": null
				},
				"sparkVersion": "3.4",
				"nodeCount": 3,
				"cores": 4,
				"memory": 28,
				"extraHeader": null
			},
			"sessionKeepAliveTimeout": 30
		},
		"cells": [
			{
				"cell_type": "code",
				"source": [
					"# Define paths\n",
					"ALL_JOURNAL_PATH = 'abfss://apc@dloadatdl.dfs.core.windows.net/silver/elsevier/all/*.csv'\n",
					"OA_JOURNAL_PATH = 'abfss://apc@dloadatdl.dfs.core.windows.net/silver/elsevier/oa/*.csv'"
				]
			},
			{
				"cell_type": "code",
				"metadata": {
					"jupyter": {
						"source_hidden": false,
						"outputs_hidden": false
					},
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"\n",
					"\n",
					"# Read data from Gen2\n",
					"all_df = spark.read.csv(ALL_JOURNAL_PATH, header=True, inferSchema=True)\n",
					"oa_df = spark.read.csv(OA_JOURNAL_PATH, header=True, inferSchema=True)\n",
					"\n",
					"# Remove duplicates\n",
					"all_df_cleaned = all_df.distinct()\n",
					"oa_df_cleaned = oa_df.distinct()\n",
					""
				]
			},
			{
				"cell_type": "code",
				"metadata": {
					"jupyter": {
						"source_hidden": false,
						"outputs_hidden": false
					},
					"nteract": {
						"transient": {
							"deleting": false
						}
					}
				},
				"source": [
					"# Write cleaned data back to the same folders (overwrite mode)\n",
					"all_df_cleaned.write.csv('abfss://apc@dloadatdl.dfs.core.windows.net/silver/elsevier/all/', header=True, mode='overwrite')\n",
					"oa_df_cleaned.write.csv('abfss://apc@dloadatdl.dfs.core.windows.net/silver/elsevier/oa/', header=True, mode='overwrite')\n",
					"print(\"Data cleaning and overwriting completed.\")"
				]
			}
		]
	}
}