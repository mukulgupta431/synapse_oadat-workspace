					"import os\n",
					"from notebookutils import mssparkutils\n",
					"\n",
					"base_path = \"abfss://openalex@dloadatdl.dfs.core.windows.net/raw/data/works/\"\n",
					"\n",
					"# List folders inside base_path\n",
					"folders = mssparkutils.fs.ls(base_path)\n",
					"\n",
					"# Extract updated_date values\n",
					"dates = [os.path.basename(f.name).replace(\"updated_date=\", \"\").replace(\"/\", \"\") for f in folders]\n",
					"\n",
					"print(dates)\n",
					""
				],
				"execution_count": 5
			},
			{
				"cell_type": "code",
				"source": [
					"base_path = \"abfss://openalex@dloadatdl.dfs.core.windows.net/raw/data/works/\"\n",
					"df = spark.read.option(\"basePath\", base_path).json(f\"{base_path}/updated_date=*/\")\n",
					"\n",
					"dates = (\n",
					"    df.select(\"updated_date\")\n",
					"      .distinct()\n",
					"      .orderBy(\"updated_date\")\n",
					"      .rdd.flatMap(lambda x: x)\n",
					"      .collect()\n",
					")\n",
					"\n",
					"print(dates)\n",
					""
				]
			}
		]
