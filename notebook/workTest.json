				"cell_type": "code",
				"source": [
					"from pyspark.sql.functions import col, length, max as spark_max\n",
					"\n",
					"# Get all string columns (you can include numeric if you want)\n",
					"string_cols = [f.name for f in df.schema.fields if f.dataType.simpleString() == 'string']\n",
					"\n",
					"# Compute max length for each string column\n",
					"exprs = [spark_max(length(col(c))).alias(c) for c in string_cols]\n",
					"\n",
					"max_lengths_df = df.select(*exprs)\n",
					"\n",
					"# Show the results\n",
					"max_lengths_df.show(truncate=False)\n",
					""
				],
